# GitHub Contribution Tool Configuration

# Git Post-Commit Backup Configuration
# Leave these empty if you don't want to use the post-commit backup hook
BACKUP_USER=
BACKUP_SERVER=
BACKUP_PATH=
BACKUP_PASSWORD=

# Number of commits to create on a specific day
DAY_COMMITS=7

# Number of commits to create within a specific week
MONTH_COMMITS=14

# Number of commits to spread throughout the year
YEAR_COMMITS=21

# Days offset from startDate for day commits (0-364)
# Leave empty for random
DAY_OFFSET=

# Weeks offset from startDate for month commits (0-51)
# Leave empty for random
WEEK_OFFSET=

# Start date for commits (ISO format, e.g., 2025-01-01)
# Leave empty to use 5 years ago from today
START_DATE=

# Test mode - when true, simulates commits without actually running git operations
# Set to 'true' or '1' to enable
TESTMODE=false
